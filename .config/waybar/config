{
  "layer": "top",
  "position": "top",
  "margin-bottom": -10,
  "spacing" : 0,

  "modules-left": [
      "hyprland/workspaces",
      "custom/uptime",
      "cpu",
      "custom/nvidia",
      "memory"
  ],

  "modules-center": ["clock", "custom/weather"],

  "modules-right": [
    "bluetooth",
    "network",
    "tray",
    "pulseaudio", 
    "backlight",
    "battery",
  ],

  "hyprland/workspaces": {
